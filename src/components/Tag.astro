---
import IconHash from "@/assets/icons/IconHash.svg";

export interface Props {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
}

const { tag, tagName, size = "sm" } = Astro.props;
---

<li
  class:list={[
    "inline-block",
    size === "sm" ? "my-1" : "mx-1 my-2.5",
  ]}
>
  <a
    href={`/tags/${tag}/`}
    transition:name={tag}
    class:list={[
      "tag focus-outline inline-flex rounded-full no-underline",
      size === "sm" ? "text-xs sm:text-sm" : "px-3 py-1.5 text-sm sm:text-base",
    ]}
  >
    <IconHash
      class:list={[
        "inline-block stroke-current",
        size === "sm" ? "mr-0.5 size-3" : "mr-1 size-4",
      ]}
    />
    <span>{tagName}</span>
  </a>
</li>

<style>
  /* Tag styles are handled by .tag class in global.css */
</style>
